# ---- Servidor ----
PORT=4000
JWT_SECRET=pon-un-secreto-largo-y-aleatorio-aqui

# ---- Correos (Resend) ----
# Sin esta clave, los correos se imprimen en consola (modo desarrollo).
# Consíguela gratis en https://resend.com -> API Keys
RESEND_API_KEY=
# Remitente. Para producción usa un dominio verificado en Resend (ej: GastosPro <facturas@tudominio.com>).
# El valor por defecto onboarding@resend.dev solo sirve para pruebas.
MAIL_FROM=GastosPro <onboarding@resend.dev>

# Días de anticipación para el aviso "por vencer" (incluye hoy y mañana).
REMINDER_DAYS_AHEAD=2
