{
  "name": "gastos-pro",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Control de gastos y facturas para negocios pequeños. Regla #1: registrar algo debe tomar menos tiempo que ignorarlo.",
  "scripts": {
    "dev": "vite",
    "server": "npm --prefix server run serve",
    "server:dev": "npm --prefix server start",
    "dev:all": "concurrently -n api,web -c green,cyan \"npm run server:dev\" \"npm run dev\"",
    "setup": "npm install && npm --prefix server install",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "tailwind-merge": "^2.6.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
